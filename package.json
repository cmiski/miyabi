{
  "name": "miyabi",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "shared",
    "services/event-producer",
    "services/notification-consumer",
    "services/analytics-consumer"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint \"**/*.ts\"",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
